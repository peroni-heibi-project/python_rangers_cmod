class IdentifiableEntity():
    def __init__(self, id:str):
        self.id = id
    
class BibliographicEntity(IdentifiableEntity):
    def __init__(self, id, title, author, publication_date, venue):
        self.title = title
        self.author = author
        self.publication_date = publication_date
        self.venue = venue
        super().__init__(id)


